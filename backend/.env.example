# --- Application ---
APP_NAME="Training Attendance & Performance Management System"
ENVIRONMENT=local

# --- Database ---
# SQLite (default, zero-install). Swap this single line to use MySQL/Postgres later, e.g.:
#   DATABASE_URL=mysql+pymysql://tapms_user:tapms_password@localhost:3306/tapms
DATABASE_URL=sqlite:///./tapms.db

# --- Auth / JWT ---
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI (Groq) ---
# MOCK_AI=true returns deterministic, realistic fixtures and needs NO API key.
# Set MOCK_AI=false and provide GROQ_API_KEY to use the real Groq backend.
MOCK_AI=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Seed control (used by Docker entrypoint in Phase 9)
SEED=false
